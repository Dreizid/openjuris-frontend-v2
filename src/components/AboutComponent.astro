---
// Import the necessary icons from lucide-react (Requires @astrojs/react integration)
// Alternatively, you can use 'astro-icon' or inline SVGs for a pure Astro setup
import { Scale, ShieldCheck, Bot, Heart, Github, Code, Globe } from 'lucide-react';
---

<div class="flex-grow flex flex-col max-w-4xl mx-auto w-full p-4 md:p-8 animate-fade-in">

  {/* Header Section */}
  <div class="text-center space-y-6 py-12 border-b border-slate-200">
    <div class="w-20 h-20 bg-blue-50 text-blue-900 rounded-2xl flex items-center justify-center mx-auto mb-4 border border-blue-100 shadow-sm">
      <Scale size={40} />
    </div>
    <h1 class="text-3xl md:text-5xl font-bold text-slate-900 tracking-tight">
      Democratizing Philippine <br class="hidden md:block" /> Legal Intelligence
    </h1>
    <p class="text-slate-500 text-lg max-w-2xl mx-auto leading-relaxed">
      BetterGov.ph is an open-source initiative dedicated to making Philippine laws, jurisprudence, and administrative issuances accessible, searchable, and understandable for every Filipino.
    </p>
  </div>

  {/* Features Grid */}
  <div class="py-12 grid grid-cols-1 md:grid-cols-3 gap-8">

    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
      <div class="w-10 h-10 bg-slate-50 rounded-lg flex items-center justify-center text-blue-900 mb-4 border border-slate-100">
        <ShieldCheck size={20} />
      </div>
      <h3 class="text-lg font-bold text-slate-900 mb-2">Verified Open Data</h3>
      <p class="text-sm text-slate-600 leading-relaxed">
        We aggregate and cross-reference documents from official sources like the Official Gazette and the SC E-Library. All data is provided "as is" and remains free for public use.
      </p>
    </div>

    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
      <div class="w-10 h-10 bg-slate-50 rounded-lg flex items-center justify-center text-blue-900 mb-4 border border-slate-100">
        <Bot size={20} />
      </div>
      <h3 class="text-lg font-bold text-slate-900 mb-2">AI-Powered Research</h3>
      <p class="text-sm text-slate-600 leading-relaxed">
        Our system utilizes Retrieval-Augmented Generation (RAG) technology to understand complex legal queries and provide accurate summaries backed by exact statutory citations.
      </p>
    </div>

    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
      <div class="w-10 h-10 bg-slate-50 rounded-lg flex items-center justify-center text-blue-900 mb-4 border border-slate-100">
        <Heart size={20} />
      </div>
      <h3 class="text-lg font-bold text-slate-900 mb-2">Community Driven</h3>
      <p class="text-sm text-slate-600 leading-relaxed">
        Built by citizens, for citizens. We rely on the public, law students, and developers to report formatting issues, update outdated laws, and improve the underlying codebase.
      </p>
    </div>

  </div>

  {/* CTA Section */}
  <div class="bg-blue-900 rounded-3xl p-8 md:p-12 text-white relative overflow-hidden mb-12 shadow-md">
    <div class="relative z-10 md:w-2/3 space-y-6">
      <h2 class="text-2xl md:text-3xl font-bold">Help us build a better system.</h2>
      <p class="text-blue-100 leading-relaxed text-sm md:text-base">
        Whether you are a developer looking to contribute to our open-source codebase on GitHub, or a legal professional willing to help verify document accuracy, there is a place for you here.
      </p>
      <div class="flex flex-wrap gap-4 pt-4">
        <a href="https://github.com/iantato/OpenJuris-Scraper" class="flex items-center gap-2 bg-white text-blue-900 px-6 py-3 rounded-lg font-bold text-sm hover:bg-blue-50 transition-colors shadow-sm">
          <Github size={18} /> View Repository
        </a>
        <a href="http://localhost:8000/api/public/docs#/" class="flex items-center gap-2 bg-blue-800 text-white border border-blue-700 px-6 py-3 rounded-lg font-bold text-sm hover:bg-blue-700 transition-colors">
          <Code size={18} /> API Documentation
        </a>
      </div>
    </div>

    {/* Background Decoration */}
    <div class="hidden md:block absolute -right-20 -top-20 opacity-10 pointer-events-none">
      <Globe size={400} />
    </div>
  </div>

  {/* Disclaimer */}
  <div class="text-center pb-12 space-y-4">
    <p class="text-xs text-slate-400 uppercase tracking-widest font-bold">Disclaimer</p>
    <p class="text-sm text-slate-500 max-w-3xl mx-auto leading-relaxed">
      BetterGov.ph is an independent, non-governmental initiative. The materials contained on this website are provided for general informational purposes only and do not constitute legal advice. While we strive to keep the information up to date and correct, we make no representations or warranties of any kind about the completeness, accuracy, or reliability of the documents.
    </p>
  </div>

</div>
---
import { Scale } from "lucide-react";
---

<footer class="bg-white border-t border-slate-200 pt-16 pb-8 px-6 sm:px-10">
	<div class="max-w-7xl mx-auto">
		<!-- Footer Top Grid -->
		<div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-8 lg:gap-12">
			<!-- Brand & Mission (Left) -->
			<div class="md:col-span-3 flex flex-col gap-4">
				<div class="flex items-center gap-2">
					<div class="bg-[#1e3a8a] p-1.5 rounded text-white inline-flex">
						<Scale size={16} />
					</div>
					<span class="font-semibold text-sm text-[#1e3a8a]">OpenJurisPH</span>
				</div>
				<p class="text-sm text-slate-500 leading-relaxed">
					Democratizing access to Philippine legal documents and jurisprudence
					through open-source technology and artificial intelligence.
				</p>
			</div>

			<!-- Downloads Navigation (Center/Left) -->
			<div class="md:col-span-5">
				<h3
					class="text-xs font-semibold text-slate-900 tracking-wider uppercase mb-5"
				>
					Archive Downloads
				</h3>
				<!-- 2-Column Grid for Links to save vertical space and look organized -->
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3">
					<a
						href="#"
						class="text-sm text-slate-500 hover:text-blue-600 hover:underline underline-offset-4 transition-all flex items-center gap-1.5 group"
					>
						<i
							data-lucide="download"
							class="w-3.5 h-3.5 opacity-0 group-hover:opacity-100 transition-opacity"
						></i>
						Republic Acts
					</a>
					<a
						href="#"
						class="text-sm text-slate-500 hover:text-blue-600 hover:underline underline-offset-4 transition-all flex items-center gap-1.5 group"
					>
						<i
							data-lucide="download"
							class="w-3.5 h-3.5 opacity-0 group-hover:opacity-100 transition-opacity"
						></i>
						Executive Orders
					</a>

					<a
						href="#"
						class="text-sm text-slate-500 hover:text-blue-600 hover:underline underline-offset-4 transition-all flex items-center gap-1.5 group"
					>
						<i
							data-lucide="download"
							class="w-3.5 h-3.5 opacity-0 group-hover:opacity-100 transition-opacity"
						></i>
						Supreme Court Decisions
					</a>
					<a
						href="#"
						class="text-sm text-slate-500 hover:text-blue-600 hover:underline underline-offset-4 transition-all flex items-center gap-1.5 group"
					>
						<i
							data-lucide="download"
							class="w-3.5 h-3.5 opacity-0 group-hover:opacity-100 transition-opacity"
						></i>
						Presidential Decrees
					</a>

					<a
						href="#"
						class="text-sm text-slate-500 hover:text-blue-600 hover:underline underline-offset-4 transition-all flex items-center gap-1.5 group"
					>
						<i
							data-lucide="download"
							class="w-3.5 h-3.5 opacity-0 group-hover:opacity-100 transition-opacity"
						></i>
						Batas Pambansa
					</a>
					<a
						href="#"
						class="text-sm text-slate-500 hover:text-blue-600 hover:underline underline-offset-4 transition-all flex items-center gap-1.5 group"
					>
						<i
							data-lucide="download"
							class="w-3.5 h-3.5 opacity-0 group-hover:opacity-100 transition-opacity"
						></i>

						Rules of Court
					</a>
				</div>
			</div>

			<!-- API Section (Right) -->
			<div class="md:col-span-4 flex flex-col md:items-end md:text-right">
				<h3
					class="text-xs font-semibold text-slate-900 tracking-wider uppercase mb-5"
				>
					Developers
				</h3>

				<!-- Modern API Endpoint Display -->
				<div
					class="w-full max-w-sm bg-slate-50 border border-slate-200 rounded-lg p-1.5 flex items-center justify-between mb-4 shadow-sm"
				>
					<div class="flex items-center gap-2 pl-2">
						<span
							class="text-[10px] font-bold tracking-wider text-green-700 bg-green-100 px-1.5 py-0.5 rounded uppercase"
							>GET</span
						>
						<code class="text-sm text-slate-600 font-mono"
							>/api/v1/documents</code
						>
					</div>
					<button
						class="p-1.5 text-slate-400 hover:text-slate-700 hover:bg-slate-200 rounded transition-colors"
						title="Copy endpoint"
						onclick="alert('Endpoint copied to clipboard!')"
					>
						<i data-lucide="copy" class="w-4 h-4"></i>
					</button>
				</div>
			</div>
		</div>

		<!-- Footer Bottom / Copyright -->
		<div
			class="mt-16 pt-8 border-t border-slate-100 flex flex-col md:flex-row justify-between items-center gap-4"
		>
			<p class="text-xs text-slate-400">
				OpenJurisPH Initiative. Open Source License (MIT).
			</p>

			<!-- Optional Socials/Extra Links -->
			<div class="flex items-center gap-4 text-slate-400">
				<a
					href="#"
					class="hover:text-slate-600 transition-colors"
					aria-label="GitHub"
				>
					<i data-lucide="github" class="w-4 h-4"></i>
				</a>

				<a
					href="#"
					class="hover:text-slate-600 transition-colors"
					aria-label="Twitter"
				>
					<i data-lucide="twitter" class="w-4 h-4"></i>
				</a>
				<span class="w-px h-4 bg-slate-200"></span>
				<a href="#" class="text-xs hover:text-slate-600 transition-colors"
					>Privacy</a
				>
				<a href="#" class="text-xs hover:text-slate-600 transition-colors"
					>Terms</a
				>
			</div>
		</div>
	</div>
</footer>

---
import { Scale } from "lucide-react";
const currentPath = Astro.url.pathname;
const active =
	"h-full flex items-center text-blue-900 border-b border-blue-900";
const inactive =
	"h-full flex hover:text-blue-900 items-center border-b border-transparent";
---

<nav class="bg-white border-solid border-b border-slate-200 top-0 sticky">
	<div class="mx-auto px-8">
		<div class="flex h-16 justify-between">
			<!-- Logo -->
			<div class="flex items-center gap-3 cursor-pointer">
				<div
					class="flex h-8 w-8 bg-blue-900 justify-center items-center font-bold rounded text-white"
				>
					<Scale size={18} />
				</div>
				<div class="flex flex-col">
					<span
						class="font-bold text-lg leading-tight tracking-tight text-blue-900"
						>OpenJuris<span class="text-red-600">PH</span>
					</span>

					<span
						class="text-[10px] uppercase tracking-wider text-slate-500 font-medium"
						>Law & Jurisprudence Archive</span
					>
				</div>
			</div>
			<!-- Selector -->
			<div class="flex items-center text-sm text-slate-600 gap-5">
				<a href="/" class={currentPath === "/" ? active : inactive}
					>AI Research</a
				>
				<a
					href="/archive"
					class={currentPath === "/archive" ? active : inactive}
					>Browse Archive</a
				>
				<a href="/" class="">About</a>
				<button class="bg-blue-900 rounded-md text-white p-2">
					Contribute
				</button>
			</div>
		</div>
	</div>
</nav>
